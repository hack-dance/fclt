{
  "name": "facult",
  "version": "2.23.0",
  "description": "Capture agent-work signal, reconcile evidence, and evolve AI capability.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hack-dance/fclt.git"
  },
  "homepage": "https://github.com/hack-dance/fclt#readme",
  "bugs": {
    "url": "https://github.com/hack-dance/fclt/issues"
  },
  "keywords": [
    "cli",
    "agents",
    "mcp",
    "skills",
    "writeback",
    "evolution",
    "feedback-loop",
    "bun"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "assets/**/*.md",
    "assets/**/*.toml",
    "bin/fclt.cjs",
    "bin/facult.cjs",
    "docs/**/*.md",
    "docs/**/*.json",
    "docs/**/*.png",
    "docs/**/*.svg",
    "plugins/fclt/.codex-plugin/*.json",
    "plugins/fclt/.mcp.json",
    "plugins/fclt/**/*.cjs",
    "plugins/fclt/**/*.js",
    "plugins/fclt/**/*.md",
    "plugins/fclt/**/*.png",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "fclt": "bin/fclt.cjs",
    "facult": "bin/facult.cjs"
  },
  "scripts": {
    "fclt": "bun run ./src/index.ts",
    "facult": "bun run ./src/index.ts",
    "scan": "bun run ./src/index.ts scan",
    "build": "bun run scripts/build-binary.ts",
    "build:verify": "bun run scripts/verify-binary.ts",
    "bootstrap:verify": "bun run scripts/verify-bootstrap-package.ts",
    "install:dev": "bun run scripts/install-cli.ts --mode=dev --force",
    "install:bin": "bun run build && bun run scripts/install-cli.ts --mode=bin --force",
    "install:status": "bun run scripts/install-status.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "type-check": "tsc --noEmit",
    "test": "./scripts/test-safe.sh",
    "test:ci": "./scripts/test-safe.sh --ci",
    "pack:dry-run": "bun run scripts/pack-dry-run.ts",
    "release:dry-run": "bunx semantic-release --dry-run --no-ci",
    "release": "bunx semantic-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/bun": "latest",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.7",
    "semantic-release": "25.0.2",
    "typescript": "5.9.3",
    "ultracite": "7.1.1"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@opentui/core": "^0.1.75",
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.8.2"
  }
}
