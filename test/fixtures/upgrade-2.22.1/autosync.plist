<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fclt.autosync</string>
  <key>ProgramArguments</key>
  <array>
    <string>__HOME_DIR__/.ai/.facult/bin/fclt</string>
    <string>autosync</string>
    <string>run</string>
    <string>--service</string>
    <string>all</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>__ROOT_DIR__</string>
  <key>StandardOutPath</key>
  <string>__HOME_DIR__/Library/Application Support/fclt/global/autosync/logs/all.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME_DIR__/Library/Application Support/fclt/global/autosync/logs/all.err.log</string>
</dict>
</plist>
